generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ORGANIZER
  ATTENDEE
  GATE_AGENT
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
  EXPIRED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  role         UserRole  @default(ATTENDEE)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  events       Event[]
  orders       Order[]
  scanLogs     ScanLog[]

  @@index([email])
  @@map("users")
}

model Event {
  id          String    @id @default(uuid())
  organizerId String    @map("organizer_id")
  title       String
  description String    @db.Text
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  location    String
  bannerUrl   String?   @map("banner_url")
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  organizer   User        @relation(fields: [organizerId], references: [id])
  ticketTypes TicketType[]
  orders      Order[]

  @@index([organizerId])
  @@index([startDate])
  @@index([isPublished])
  @@map("events")
}

model TicketType {
  id           String   @id @default(uuid())
  eventId      String   @map("event_id")
  name         String
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  quantity     Int
  soldCount    Int      @default(0) @map("sold_count")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]

  @@index([eventId])
  @@map("ticket_types")
}

model Order {
  id              String      @id @default(uuid())
  userId          String?     @map("user_id")
  eventId         String      @map("event_id")
  guestName       String?     @map("guest_name")
  guestEmail      String?     @map("guest_email")
  guestPhone      String?     @map("guest_phone")
  totalAmount     Decimal     @db.Decimal(10, 2) @map("total_amount")
  status          OrderStatus @default(PENDING)
  paystackRef     String?     @unique @map("paystack_ref")
  paystackChannel String?     @map("paystack_channel")
  paidAt          DateTime?   @map("paid_at")
  metadata        Json?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user            User?       @relation(fields: [userId], references: [id])
  event           Event       @relation(fields: [eventId], references: [id])
  orderItems      OrderItem[]
  tickets         Ticket[]

  @@index([userId])
  @@index([eventId])
  @@index([paystackRef])
  @@index([status])
  @@index([guestPhone])
  @@map("orders")
}

model OrderItem {
  id           String     @id @default(uuid())
  orderId      String     @map("order_id")
  ticketTypeId String     @map("ticket_type_id")
  quantity     Int
  unitPrice    Decimal    @db.Decimal(10, 2) @map("unit_price")
  createdAt    DateTime   @default(now()) @map("created_at")

  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Ticket {
  id           String       @id @default(uuid())
  orderId      String       @map("order_id")
  ticketTypeId String       @map("ticket_type_id")
  eventId      String       @map("event_id")
  holderId     String?      @map("holder_id")
  entryPin     String?      @map("entry_pin")
  status       TicketStatus @default(ACTIVE)
  qrPayload    String       @unique @map("qr_payload") @db.Text
  qrImageUrl   String?      @map("qr_image_url")
  isUsed       Boolean      @default(false) @map("is_used")
  scannedAt    DateTime?    @map("scanned_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  order        Order        @relation(fields: [orderId], references: [id])
  scanLogs     ScanLog[]

  @@unique([eventId, entryPin])
  @@index([orderId])
  @@index([eventId])
  @@index([holderId])
  @@index([isUsed])
  @@index([status])
  @@map("tickets")
}

model ScanLog {
  id         String   @id @default(uuid())
  ticketId   String   @map("ticket_id")
  scannedBy  String   @map("scanned_by")
  eventId    String   @map("event_id")
  result     String
  ipAddress  String?  @map("ip_address")
  deviceInfo String?  @map("device_info")
  createdAt  DateTime @default(now()) @map("created_at")

  ticket     Ticket   @relation(fields: [ticketId], references: [id])
  agent      User     @relation(fields: [scannedBy], references: [id])

  @@index([ticketId])
  @@index([eventId])
  @@index([scannedBy])
  @@map("scan_logs")
}
